+// gateway --cookie-authority`, spawned by ports/strapi/suite.mts). Everything above
+// them — default headers, token refresh, FetchError shaping, RTK Query — runs
+// untouched. Crossability is the framework's (tierless/adapt-fetch): JSON negotiation
+// crosses; FormData, binary, external origins stay on stock fetch; abort races the
+// crossing. Cookie authority auto-engages from the gateway's hello declaration — auth
+// flows cross too, each crossing carrying the sealed jar blob (httpOnly preserved);
+// awaitClaims because this suite reads/clears the jar the instant auth flows settle.
+// Under SSR the stock fetch stays.
+const tierlessFetch = typeof window === 'undefined'
+  ? ((url: string | URL, init?: RequestInit) => fetch(url, init))
+  : fetchAdapter({ exec: autoSession({ awaitClaims: true }).exec, origin: () => window.strapi?.backendURL || '/' });
 
