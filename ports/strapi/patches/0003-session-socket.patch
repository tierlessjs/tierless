+// preconnected so the upgrade handshake never lands on an interaction's critical path.
+// `tierlessWsUrl` (localStorage, set by the suite's global setup) lets measured runs
+// route the socket through a shaping relay.
+let configured = false;
+const makeExec = (_apiOrigin: string) => {
+  if (!configured) {
+    configured = true;
+    // bounded per-crossing log ({t, url, status, body}) — the suite's transport-
+    // agnostic waits read it (tests/utils/shared.ts, test patch)
+    (window as unknown as { __TIERLESS_EXEC_LOG__?: boolean }).__TIERLESS_EXEC_LOG__ = true;
+    const wsUrl = localStorage.getItem('tierlessWsUrl');
+    // scheme follows the page (an https page blocks ws:// as mixed content)
+    configureTierless({
+      url: () =>
+        wsUrl ||
+        `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.hostname}:8180/__tierless`,
+      preconnect: true,
+    });
+  }
+  return sessionExec();
+};
 
