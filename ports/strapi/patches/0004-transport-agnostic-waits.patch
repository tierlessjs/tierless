+): Promise<unknown> => {
+  const httpWait = page.waitForResponse(
+    (response) =>
+      response.request().method() === method &&
+      urlIncludes.every((s) => response.url().includes(s)) &&
+      (!urlIncludesAny || urlIncludesAny.some((s) => response.url().includes(s))) &&
