+      const log = ((window as unknown as { __tierlessExecLog?: unknown[] }).__tierlessExecLog ||
+        []) as { t: number; name: string; url: string; status?: number }[];
+      return log.some(
+        (e) =>
+          e &&
+          e.t >= from &&
+          ((e.name || '').split('.')[1] || '').toUpperCase() === method &&
+          urlIncludes.every((s) => (e.url || '').includes(s)) &&
+          (!urlIncludesAny || urlIncludesAny.some((s) => (e.url || '').includes(s))) &&
+          typeof e.status === 'number' &&
+          e.status >= 200 &&
+          e.status < 300
+      );
+    },
+    { from, method, urlIncludes, urlIncludesAny: urlIncludesAny ?? null }
+  );
