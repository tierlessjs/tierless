+/**
+ * The tierless I/O bottom for the Strapi admin (corpus port, docs/corpus.md rung 3).
+ *
+ * getFetchClient's four raw `fetch(...)` call sites route through here — everything
+ * above (default headers, token refresh, FetchError shaping, RTK Query's baseQuery)
+ * runs untouched. A crossable request is refashioned as a tierless resource request
+ * (`api.<method>`, origin-relative path, explicit headers — the Authorization bearer
+ * their client attached rides in the request; no ambient authority) and the reply is
+ * rebuilt into a real `Response` for their own responseInterceptor to parse.
+ *
+ * NOT crossable — falls through to the host fetch, stock behavior:
+ *   - FormData bodies (media uploads: the browser owns multipart framing),
+ *   - requests not negotiating JSON (getFetchClient omits `Accept: application/json`
+ *     exactly when responseType is blob/text/arrayBuffer — binary can't cross a JSON
+ *     envelope),
+ *   - URLs leaving the client's own backend origin (external I/O, never a crossing),
+ *   - auth flows (login/logout/register/reset/access-token): their responses SET the
+ *     httpOnly refresh cookie — cookie-jar writes exist only in the browser, and a
+ *     reply reconstructed from a crossing cannot perform them. Pinned by meaning,
+ *     matching their own client's isAuthPath special-casing.
+ *
+ * AbortSignal is handled HERE, browser-side, instead of pinning the request to stock
+ * (the axios-adapter posture): Strapi's RTK Query layer attaches a signal to EVERY
+ * request, so signal-pins would leave nothing at the socket. Abort races the crossing:
+ * the caller sees an immediate AbortError (fetch semantics), the crossing's eventual
+ * reply is discarded. Divergence from stock: the wire is not torn down mid-flight —
+ * for this API's small JSON bodies the server completes the handler either way.
+ */
+import { restResources } from 'tierless/adapt';
+
+interface Envelope {
+  status: number;
+  headers: Record<string, string>;
+  body: unknown;
+}
+
+// The exec servicing crossings: a direct fetch against the client's own backend origin
+// (stock behavior, byte for byte — the certification arm). The session-socket exec
+// replaces this in the next patch.
+const makeExec = (apiOrigin: string) => restResources(apiOrigin, { envelopeErrors: true });
+
+const abortError = () =>
+  typeof DOMException !== 'undefined'
+    ? new DOMException('The operation was aborted.', 'AbortError')
+    : Object.assign(new Error('The operation was aborted.'), { name: 'AbortError' });
+
+const NO_BODY_STATUS = new Set([204, 205, 304]);
+
+// Auth endpoints whose responses set/clear the httpOnly refresh cookie (their server's
+// authentication controller), plus the rest of the login-page flows for symmetry.
+const AUTH_PATH =
+  /\/admin\/(login|logout|register|register-admin|registration-info|forgot-password|reset-password|access-token|renew-token)\b/;
+
+export const tierlessFetch = async (url: string, init: RequestInit): Promise<Response> => {
+  const method = String(init.method || 'GET').toLowerCase();
+  const headers = new Headers(init.headers);
+  const apiOrigin = new URL(
+    (typeof window !== 'undefined' && window.strapi?.backendURL) || '/',
+    typeof location !== 'undefined' ? location.href : 'http://localhost'
+  ).origin;
+  const target = new URL(url, typeof location !== 'undefined' ? location.href : apiOrigin);
+
+  const crossable =
+    typeof window !== 'undefined' &&
+    target.origin === apiOrigin &&
+    !AUTH_PATH.test(target.pathname) &&
+    (init.body === undefined || init.body === null || typeof init.body === 'string') &&
+    (headers.get('accept') || '').includes('application/json');
+
+  if (!crossable) {
+    return fetch(url, init);
+  }
+
+  if (init.signal?.aborted) throw abortError();
+
+  const plainHeaders: Record<string, string> = {};
+  headers.forEach((v, k) => {
+    plainHeaders[k] = v;
+  });
+
+  const crossing = Promise.resolve(
+    makeExec(apiOrigin)({
+      op: 'resource',
+      tier: 'server',
+      name: `api.${method}`,
+      // ORIGIN-RELATIVE on purpose: whoever executes the request binds the path to ITS
+      // OWN base (browser exec: this origin; a session gateway: its localhost backend).
+      args: [
+        target.pathname + target.search,
+        init.body === undefined || init.body === null ? undefined : init.body,
+        { headers: plainHeaders },
+      ],
+    })
+  ) as Promise<Envelope>;
+
+  let envelope: Envelope;
+  if (init.signal) {
+    const signal = init.signal;
+    envelope = await new Promise<Envelope>((resolve, reject) => {
+      const onAbort = () => reject(abortError());
+      signal.addEventListener('abort', onAbort, { once: true });
+      crossing.then(
+        (v) => {
+          signal.removeEventListener('abort', onAbort);
+          resolve(v);
+        },
+        (e) => {
+          signal.removeEventListener('abort', onAbort);
+          reject(e);
+        }
+      );
+    });
+  } else {
+    envelope = await crossing;
+  }
+
+  const text = typeof envelope.body === 'string' ? envelope.body : JSON.stringify(envelope.body);
+  return new Response(NO_BODY_STATUS.has(envelope.status) || text === '' ? null : text, {
+    status: envelope.status,
+    headers: envelope.headers,
+  });
+};
