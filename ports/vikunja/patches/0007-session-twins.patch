+++ b/frontend/src/tierlessNodeShims.ts
@@ -0,0 +1,15 @@
+// Node shims for the session-twin bundle (tierless, docs/migrate-arm.md). MUST be the
+// twins module's first import: the service graph constructs module-level singletons
+// (AvatarService) whose factories read window.API_URL at import time. Values are filled
+// per session by makeTwins(); single-session-safe (see tierlessTwins.ts).
+if (typeof window === 'undefined') {
+	// eslint-disable-next-line @typescript-eslint/no-explicit-any
+	;(globalThis as any).window = {API_URL: process.env.TIERLESS_API_URL || 'http://127.0.0.1:3456'}
+	// eslint-disable-next-line @typescript-eslint/no-explicit-any
+	;(globalThis as any).localStorage = {
+		// eslint-disable-next-line @typescript-eslint/no-explicit-any
+		getItem: (k: string) => (k === 'token' ? ((globalThis as any).__TIERLESS_TWIN_TOKEN__ ?? null) : null),
+		setItem() {}, removeItem() {},
+	}
+}
+export {}
