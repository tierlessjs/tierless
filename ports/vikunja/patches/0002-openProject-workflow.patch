diff --git a/frontend/tierless/openProject.src.js b/frontend/tierless/openProject.src.js
new file mode 100644
--- /dev/null
+++ b/frontend/tierless/openProject.src.js
@@ -0,0 +1,22 @@
+"use tierless";
+// The open-a-project workflow: everything this route's views fetch, as ONE migrating
+// continuation — user, project, and the view's task page, served next to the API and
+// shipped back in a single crossing. Keys are the request paths the app's own
+// components will ask for; the tierless shim answers them locally.
+const TASKS_QUERY = "sort_by[]=position&order_by[]=asc&filter=&filter_include_nulls=false&filter_timezone=&s=&expand[]=subtasks&expand[]=comment_count&expand[]=is_unread&page=1";
+
+export function openProject(id, view) {
+  const user = api.get("/api/v1/user");
+  const project = api.get("/api/v1/projects/" + id);
+  // view "0" (or absent) means "the project's default view" — resolve it like the app does
+  let v = view;
+  if (!v || v === "0") {
+    v = project.body.views && project.body.views.length ? "" + project.body.views[0].id : "1";
+  }
+  const tasks = api.get("/api/v1/projects/" + id + "/views/" + v + "/tasks?" + TASKS_QUERY);
+  const out = {};
+  out["/api/v1/user"] = user;
+  out["/api/v1/projects/" + id] = project;
+  out["/api/v1/projects/" + id + "/views/" + v + "/tasks?" + TASKS_QUERY] = tasks;
+  return out;
+}
