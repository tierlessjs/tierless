--- a/packages/testing/playwright/utils/transport-wait.ts
+++ b/packages/testing/playwright/utils/transport-wait.ts
@@ -0,0 +1,97 @@
+// Transport-agnostic REST wait (tierless corpus harness, test patch 0006 — applied to
+// BOTH arms; docs/corpus.md test accommodations). The ported build serves same-origin
+// /rest requests over a session websocket, so `page.waitForResponse` can never fire
+// for them. This helper races the HTTP wait against the page's tierless exec log
+// (same url/method/status predicate) and returns a Response-LIKE object either way,
+// so call sites keep their `.json()` / `.request().postDataJSON()` shape unchanged.
+// On the stock build the log never exists and the race reduces to the original wait.
+import type { Page, Response } from '@playwright/test';
+
+export interface RestWaitOptions {
+	/** Substrings that must ALL appear in the url, or a RegExp. */
+	url: string[] | RegExp;
+	/** Uppercase methods to accept; empty/omitted accepts any. */
+	methods?: string[];
+	timeout?: number;
+}
+
+export interface RestResponseLike {
+	url(): string;
+	status(): number;
+	json(): Promise<unknown>;
+	request(): { method(): string; postData(): string | null; postDataJSON(): unknown };
+}
+
+interface ExecLogEntry {
+	t: number;
+	name: string;
+	url: string;
+	status?: number;
+	reqBody?: unknown;
+	body?: unknown;
+}
+
+const fromResponse = (res: Response): RestResponseLike => res;
+
+const fromEntry = (e: ExecLogEntry): RestResponseLike => ({
+	url: () => e.url,
+	status: () => e.status ?? 200,
+	json: async () => e.body,
+	request: () => ({
+		method: () => (e.name || '').split('.')[1]?.toUpperCase() ?? '',
+		postData: () => (e.reqBody === undefined ? null : JSON.stringify(e.reqBody)),
+		postDataJSON: () => e.reqBody,
+	}),
+});
+
+export async function waitForRestResponseOrCrossing(
+	page: Page,
+	{ url, methods = [], timeout }: RestWaitOptions,
+): Promise<RestResponseLike> {
+	const urlOk = (u: string): boolean =>
+		url instanceof RegExp ? url.test(u) : url.every((s) => u.includes(s));
+	// a TIMESTAMP, not an index cursor: the awaited action may navigate, which resets
+	// the page world and restarts the log — wall clock stays comparable across documents
+	const logFrom = await page.evaluate(() => Date.now()).catch(() => Date.now());
+	const httpWait = page.waitForResponse(
+		(res) => urlOk(res.url()) && (methods.length === 0 || methods.includes(res.request().method())),
+		timeout !== undefined ? { timeout } : undefined,
+	);
+	const crossingWait = page
+		.waitForFunction(
+			({ from, reSrc, reFlags, subs, ms }) => {
+				const log = ((window as unknown as { __tierlessExecLog?: ExecLogEntry[] })
+					.__tierlessExecLog ?? []) as ExecLogEntry[];
+				for (const e of log) {
+					if (!e || e.t < from || e.status === undefined) continue;
+					const method = (e.name || '').split('.')[1]?.toUpperCase() ?? '';
+					const ok =
+						reSrc !== null
+							? new RegExp(reSrc, reFlags ?? '').test(e.url)
+							: (subs as string[]).every((s) => e.url.includes(s));
+					if (ok && ((ms as string[]).length === 0 || (ms as string[]).includes(method)))
+						return JSON.stringify(e);
+				}
+				return '';
+			},
+			{
+				from: logFrom,
+				reSrc: url instanceof RegExp ? url.source : null,
+				reFlags: url instanceof RegExp ? url.flags : null,
+				subs: url instanceof RegExp ? [] : url,
+				ms: methods,
+			},
+			timeout !== undefined ? { timeout } : undefined,
+		)
+		.then(async (h) => {
+			const s = (await h.jsonValue()) as string;
+			return fromEntry(JSON.parse(s) as ExecLogEntry);
+		});
+	// the losing wait's eventual timeout must not surface as an unhandled rejection
+	void httpWait.catch(() => {});
+	void crossingWait.catch(() => {});
+	return await Promise.race([
+		httpWait.then(fromResponse),
+		crossingWait,
+	]);
+}
