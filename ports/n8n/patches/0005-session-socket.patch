+// The session socket (corpus port, patch 0005): same-origin requests cross a ws
+// session to the gateway at page-port+100 (ports/n8n/gateway.mts) as one exec crossing
+// each — preflights gone, envelope headers trimmed, one session-long deflate window.
+// n8n's authority is an httpOnly cookie, so each crossing carries a sealed blob
+// (tierless/adapt-session-auth): reseal at startup, in-band rotation on any mediated
+// set-cookie (login included — it crosses too), a claim keeps the real jar current for
+// reloads, and a 401 reseals from the jar and retries once (another tab logged out).
+let tierlessSession: ReturnType<ReturnType<typeof cookieSessionAuth>['wrap']> | undefined;
+function tierlessSessionExec() {
+	if (!tierlessSession) {
+		const port = Number(location.port || (location.protocol === 'https:' ? 443 : 80)) + 100;
+		// bounded per-crossing log ({t, url, status, reqBody, body}) — the suite's
+		// transport-agnostic waits read it (test patch 0006); zero cost outside tests
+		(window as { __TIERLESS_EXEC_LOG__?: boolean }).__TIERLESS_EXEC_LOG__ = true;
+		configureTierless({
+			url: () =>
+				`${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.hostname}:${port}/__tierless`,
+			preconnect: true,
+		});
+		tierlessSession = cookieSessionAuth({
+			gateway: `${location.protocol}//${location.hostname}:${port}`,
+		}).wrap(sessionExec());
+	}
+	return tierlessSession;
+}
