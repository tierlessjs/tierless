+// The session socket (corpus port): same-origin requests cross a ws
+// session to the gateway at page-port+100 (ports/n8n/gateway.mts) as one exec crossing
+// each — preflights gone, envelope headers trimmed, one session-long deflate window.
+// n8n's authority is an httpOnly cookie, so each crossing carries a sealed blob
+// (tierless/adapt-session-auth): reseal at startup, in-band rotation on any mediated
+// set-cookie (login included — it crosses too), a claim keeps the real jar current for
+// reloads, and a 401 reseals from the jar and retries once (another tab logged out).
+let tierlessSession: ReturnType<ReturnType<typeof cookieSessionAuth>['wrap']> | undefined;
+function tierlessSessionExec() {
+	if (!tierlessSession) {
+		const port = Number(location.port || (location.protocol === 'https:' ? 443 : 80)) + 100;
+		// bounded per-crossing log ({t, url, status, reqBody, body}) — the suite's
+		// transport-agnostic waits read it (test patch); zero cost outside tests
+		(window as { __TIERLESS_EXEC_LOG__?: boolean }).__TIERLESS_EXEC_LOG__ = true;
+		configureTierless({
+			url: () =>
+				`${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.hostname}:${port}/__tierless`,
+			preconnect: true,
+		});
+		// hello: the gateway seals THIS socket's cookie at the upgrade and pre-fetches the
+		// boot GETs, delivered before any crossing — so the startup blob rides the handshake
+		// (no reseal round trip) and the first boot GETs join the preboot buffer.
+		tierlessSession = cookieSessionAuth({
+			gateway: `${location.protocol}//${location.hostname}:${port}`,
+			hello: sessionHello(),
+		}).wrap(sessionExec());
+	}
+	return tierlessSession;
+}
+
+// FORCE-BROWSER (corpus port): a request whose URL matches a glob the page
+// registered in `window.__tierlessForceBrowser` stays on the browser's own fetch
+// instead of the socket. Moving I/O off the browser makes it invisible to anything
+// that intercepts browser network traffic — service workers, extensions, and (the
+// reason it surfaced) a test harness's response mocking. The embedder lists the
+// resources that MUST stay browser-visible; empty/absent in production, so this is a
+// no-op there. Populated by a test patch from the suite's own route() registrations.
+type ForceGlob = { glob: string } | { re: [string, string] };
+function forceBrowser(path: string): boolean {
+	const list = (window as { __tierlessForceBrowser?: ForceGlob[] }).__tierlessForceBrowser;
+	if (!list || !list.length) return false;
+	const full = location.origin + path;
+	const candidates = [full, full.split('?')[0]];
+	const globToRe = (g: string): RegExp =>
+		new RegExp(
+			'^' +
+				g
+					.replace(/[.+^${}()|[\]\\]/g, '\\$&')
+					.replace(/\*\*|\*|\?/g, (m) => (m === '**' ? '.*' : m === '*' ? '[^/]*' : '.')) +
+				'$',
+		);
+	return list.some((d) => {
+		const re = 're' in d ? new RegExp(d.re[0], d.re[1]) : globToRe(d.glob);
+		return candidates.some((c) => re.test(c));
+	});
+}
+
+// same-origin exec: force-browser paths take the direct fetch (interceptable), the rest
+// cross the session socket. Built once per origin; the per-request choice is inside.
+function tierlessSameOriginExec(origin: string) {
+	const direct = restResources(origin, { envelopeErrors: true });
+	const session = tierlessSessionExec();
+	return (req: Parameters<typeof session>[0]) =>
+		forceBrowser(String((req.args ?? [])[0] ?? '')) ? direct(req) : session(req);
+}
