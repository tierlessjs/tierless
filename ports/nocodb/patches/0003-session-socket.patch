@@ -1,7 +1,18 @@
 import axios from 'axios'
 import { axiosAdapter } from 'tierless/adapt-axios'
-import { restResources } from 'tierless/adapt'
+import { configureTierless, sessionExec } from 'tierless/browser'
 import type { Api } from 'nocodb-sdk'
+
+// The session gateway (corpus port, patch 0003): the UI is served by nuxt on :3000,
+// the session ws rides the standalone gateway on :8180 (ports/nocodb/gateway.mts) —
+// explicit URL, preconnected at app boot so the upgrade handshake never lands on the
+// first interaction's critical path. Measured runs may inject an override global.
+if (typeof window !== 'undefined') {
+  configureTierless({
+    url: () => (window as any).__TIERLESS_WS__ || `ws://${location.hostname}:8180/__tierless`,
+    preconnect: true,
+  })
+}
 const DbNotFoundMsg = 'Database config not found'
 
 const TIMEOUT_RETRY_COUNT = 1
@@ -21,8 +32,11 @@
   // direct fetch to the API origin — stock behavior. Browser-pinned configs (progress,
   // blobs, FormData) fall through to axios's own XHR adapter (absent under Node/SSR).
   axiosInstance.defaults.adapter = axiosAdapter({
-    // the instance's own baseURL, read per request — same source their requests use
-    exec: (req) => restResources(new URL(axiosInstance.defaults.baseURL || '/', location.href).origin, { envelopeErrors: true })(req),
+    // patch 0003: requests cross the SESSION SOCKET (one exec crossing per request,
+    // executed by the gateway against the backend over localhost) instead of direct
+    // fetch. Authority rides in each request's own headers — their interceptor chain
+    // attached xc-auth above before the adapter ever sees the config.
+    exec: sessionExec(),
     fallback: typeof XMLHttpRequest === 'undefined' ? undefined : axios.getAdapter('xhr'),
   })
 
