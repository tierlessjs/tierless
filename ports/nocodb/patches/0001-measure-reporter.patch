diff -ruN a/tests/playwright/tierlessMeasureReporter.ts b/tests/playwright/tierlessMeasureReporter.ts
--- a/tests/playwright/tierlessMeasureReporter.ts	1970-01-01 00:00:00.000000000 +0000
+++ b/tests/playwright/tierlessMeasureReporter.ts	2026-07-09 13:55:23.789037029 +0000
@@ -0,0 +1,59 @@
+// Per-test measurement reporter (tierless corpus harness, docs/corpus.md): appends one
+// JSONL row per test ATTEMPT to TIERLESS_MEASURE_OUT — id, status, retry, durationMs.
+// With TIERLESS_WIRE_URLS set (comma-separated endpoints returning flat JSON number
+// counters), reads them around each attempt and records the deltas as wire* fields.
+// The sqlite lane runs workers=1, so no two tests generate traffic at once; but
+// Playwright does NOT await async reporter hooks, so a snapshot can lag its boundary
+// and mis-attribute between ADJACENT tests — per-test deltas are best-effort (fine
+// for medians), while the byte instrument of record is the TCP-true pair of runs.
+// A counter read that fails INVALIDATES the row (wireError: true, no wire fields)
+// instead of shipping wrong deltas — a missed BEGIN read would silently attribute all
+// prior suite traffic to this test; report.mts excludes flagged rows and says so.
+import type { Reporter, TestCase, TestResult } from '@playwright/test/reporter';
+import { appendFileSync } from 'fs';
+
+const OUT = process.env.TIERLESS_MEASURE_OUT;
+const WIRE = (process.env.TIERLESS_WIRE_URLS || '').split(',').filter(Boolean);
+
+// null = a configured endpoint was unreachable or non-2xx: this attempt has no valid deltas
+async function counters(): Promise<Record<string, number> | null> {
+  const out: Record<string, number> = {};
+  for (const url of WIRE) {
+    try {
+      const r = await fetch(url);
+      if (!r.ok) return null;
+      const j = (await r.json()) as Record<string, unknown>;
+      for (const [k, v] of Object.entries(j)) if (typeof v === 'number') out[k] = (out[k] || 0) + v;
+    } catch {
+      return null;
+    }
+  }
+  return out;
+}
+
+class TierlessMeasure implements Reporter {
+  private before: Record<string, number> | null = {};
+  async onTestBegin(_test: TestCase) {
+    if (WIRE.length) this.before = await counters();
+  }
+  async onTestEnd(test: TestCase, result: TestResult) {
+    if (!OUT) return;
+    const after = WIRE.length ? await counters() : {};
+    const wire: Record<string, number | boolean> = {};
+    if (WIRE.length && (!this.before || !after)) {
+      wire.wireError = true;
+    } else if (after) {
+      for (const k of Object.keys(after)) wire['wire' + k[0].toUpperCase() + k.slice(1)] = after[k] - (this.before![k] || 0);
+    }
+    const file = test.location.file.replace(/^.*tests\/playwright\//, '');
+    const titles = test.titlePath().filter((t) => t && !t.endsWith('.spec.ts') && t !== 'chromium');
+    appendFileSync(
+      OUT,
+      JSON.stringify({ id: `${file}:${test.location.line} › ${titles.join(' › ')}`, status: result.status, retry: result.retry, durationMs: result.duration, ...wire }) + '\n',
+    );
+  }
+  printsToStdio() {
+    return false;
+  }
+}
+export default TierlessMeasure;
