{
  "name": "tierless",
  "version": "0.2.1",
  "type": "module",
  "description": "Tierless continuation migration \u2014 one program that runs across browser and server, with the runtime moving live execution between tiers as serializable continuations.",
  "keywords": [
    "continuation",
    "migration",
    "tierless",
    "isomorphic",
    "client-server",
    "serialization",
    "distributed"
  ],
  "homepage": "https://github.com/tierlessjs/tierless#readme",
  "bugs": {
    "url": "https://github.com/tierlessjs/tierless/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tierlessjs/tierless.git",
    "directory": "packages/tierless"
  },
  "license": "Apache-2.0",
  "author": "Bright Fulton",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.bin.json"
  },
  "files": [
    "src",
    "bin",
    "types"
  ],
  "exports": {
    ".": {
      "types": "./types/host.d.mts",
      "default": "./src/host.mjs"
    },
    "./api": {
      "types": "./types/api/index.d.mts",
      "default": "./src/api/index.mjs"
    },
    "./server": {
      "types": "./types/server.d.mts",
      "default": "./src/server.mjs"
    },
    "./browser": {
      "types": "./types/browser.d.mts",
      "default": "./src/browser.mjs"
    },
    "./react": {
      "types": "./types/react.d.mts",
      "default": "./src/react.mjs"
    },
    "./vite": {
      "types": "./types/vite.d.mts",
      "default": "./src/vite.mjs"
    },
    "./compiler": {
      "types": "./types/compiler.d.cts",
      "default": "./src/transform.cjs"
    },
    "./runtime": {
      "types": "./types/runtime.d.mts",
      "default": "./src/runtime.mjs"
    },
    "./wire": {
      "types": "./types/wire-binary.d.mts",
      "default": "./src/wire-binary.mjs"
    },
    "./delta": {
      "types": "./types/wire-delta.d.mts",
      "default": "./src/wire-delta.mjs"
    },
    "./graph": {
      "types": "./types/graph.d.mts",
      "default": "./src/graph.mjs"
    },
    "./heap": {
      "types": "./types/heap.d.mts",
      "default": "./src/heap.mjs"
    },
    "./fetch": {
      "types": "./types/fetch.d.mts",
      "default": "./src/fetch.mjs"
    },
    "./store": {
      "types": "./types/store.d.mts",
      "default": "./src/store.mjs"
    },
    "./coherence": {
      "types": "./types/coherence.d.mts",
      "default": "./src/coherence.mjs"
    },
    "./content": {
      "types": "./types/content.d.mts",
      "default": "./src/content.mjs"
    },
    "./transport": {
      "types": "./types/transport.d.mts",
      "default": "./src/transport.mjs"
    },
    "./trace": {
      "types": "./types/trace.d.mts",
      "default": "./src/trace.mjs"
    },
    "./adapt": {
      "types": "./types/adapt.d.mts",
      "default": "./src/adapt.mjs"
    },
    "./adapt-axios": {
      "types": "./types/adapt-axios.d.mts",
      "default": "./src/adapt-axios.mjs"
    },
    "./session-auth": {
      "types": "./types/session-auth.d.mts",
      "default": "./src/session-auth.mjs"
    },
    "./adapt-session-auth": {
      "types": "./types/adapt-session-auth.d.mts",
      "default": "./src/adapt-session-auth.mjs"
    },
    "./adapt-fetch": {
      "types": "./types/adapt-fetch.d.mts",
      "default": "./src/adapt-fetch.mjs"
    },
    "./adapt-auto": {
      "types": "./types/adapt-auto.d.mts",
      "default": "./src/adapt-auto.mjs"
    },
    "./playwright": {
      "types": "./types/playwright.d.mts",
      "default": "./src/playwright.mjs"
    },
    "./playwright-reporter": {
      "types": "./types/playwright-reporter.d.mts",
      "default": "./src/playwright-reporter.mjs"
    },
    "./playwright-register": {
      "types": "./types/playwright-register.d.cts",
      "default": "./src/playwright-register.cjs"
    }
  },
  "bin": {
    "tierless": "bin/tierless.mjs"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17"
  },
  "types": "./types/host.d.mts"
}
