{
  "name": "tierless",
  "version": "0.1.0",
  "type": "module",
  "description": "Tierless continuation migration — one program that runs across browser and server, with the runtime moving live execution between tiers as serializable continuations.",
  "keywords": [
    "continuation",
    "migration",
    "tierless",
    "isomorphic",
    "client-server",
    "serialization",
    "distributed"
  ],
  "homepage": "https://github.com/tierlessjs/tierless#readme",
  "bugs": {
    "url": "https://github.com/tierlessjs/tierless/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tierlessjs/tierless.git",
    "directory": "packages/tierless"
  },
  "license": "Apache-2.0",
  "author": "Bright Fulton",
  "files": [
    "src",
    "bin",
    "types"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/host.mjs"
    },
    "./api": {
      "types": "./types/api.d.ts",
      "default": "./src/api/index.mjs"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "default": "./src/server.mjs"
    },
    "./browser": {
      "types": "./types/browser.d.ts",
      "default": "./src/browser.mjs"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "default": "./src/react.mjs"
    },
    "./vite": {
      "types": "./types/vite.d.ts",
      "default": "./src/vite.mjs"
    },
    "./compiler": {
      "types": "./types/compiler.d.ts",
      "default": "./src/transform.cjs"
    },
    "./runtime": {
      "types": "./types/runtime.d.ts",
      "default": "./src/runtime.mjs"
    },
    "./wire": {
      "types": "./types/wire.d.ts",
      "default": "./src/wire-binary.mjs"
    },
    "./delta": {
      "types": "./types/delta.d.ts",
      "default": "./src/wire-delta.mjs"
    },
    "./graph": {
      "types": "./types/graph.d.ts",
      "default": "./src/graph.mjs"
    },
    "./heap": {
      "types": "./types/heap.d.ts",
      "default": "./src/heap.mjs"
    },
    "./fetch": {
      "types": "./types/fetch.d.ts",
      "default": "./src/fetch.mjs"
    },
    "./content": {
      "types": "./types/content.d.ts",
      "default": "./src/content.mjs"
    },
    "./transport": {
      "types": "./types/transport.d.ts",
      "default": "./src/transport.mjs"
    }
  },
  "bin": {
    "tierless": "bin/tierless.mjs"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "ws": "^8.21.0"
  },
  "types": "./types/index.d.ts"
}
